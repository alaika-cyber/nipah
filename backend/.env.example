# Nipah Virus Awareness Platform - Environment Configuration
# Copy this file to .env and fill in your values

# Set to "true" for development mode with auto-reload
DEBUG=false

# OpenAI API Key (optional - the chatbot works without it using built-in knowledge base)
OPENAI_API_KEY=

# LLM Model to use (gpt-3.5-turbo, gpt-4, gpt-4o, etc.)
LLM_MODEL=gpt-3.5-turbo

# Frontend URLs allowed to access the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
