# Nipah Virus Awareness Platform - Environment Configuration
# Copy this file to .env and fill in your values

# Set to "true" for development mode with auto-reload
DEBUG=false

# OpenAI API Key (optional - the chatbot works without it using built-in knowledge base)
OPENAI_API_KEY=

# Local LLM Base URL (optional - use for local models like LM Studio, Ollama at http://localhost:4141/v1)
LLM_BASE_URL=

# LLM Model to use (gpt-3.5-turbo, gpt-4, gpt-4o, etc. or your local model name)
LLM_MODEL=gpt-3.5-turbo

# Frontend URLs allowed to access the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLite database file path
SQLITE_DB_PATH=./data/nipah.db

# Default login credentials (seeded automatically at backend startup)
DEFAULT_ADMIN_EMAIL=admin@nipah.local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_MANAGER_EMAIL=manager@nipah.local
DEFAULT_MANAGER_PASSWORD=manager123
